<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.haoticdance.bookreaderintellijplugin</id>
    <name>R3 Book Reader</name>
    <vendor>haoticdance</vendor>
    <description><![CDATA[
        R3 Book Reader: Read EPUB, FB2, MOBI and PDF books directly in your IDE.
        <p>Features:</p>
        <ul>
            <li>Modern R3 Branding</li>
            <li>EPUB, FB2, MOBI, PDF support</li>
            <li>Light / Night theme</li>
            <li>Recent books tool window</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Book"
                  implementationClass="com.github.haoticdance.bookreaderintellijplugin.fileTypes.BookFileType"
                  fieldName="INSTANCE" extensions="fb2;epub;pdf;mobi"/>
        <fileEditorProvider
                implementation="com.github.haoticdance.bookreaderintellijplugin.editor.BookFileEditorProvider"/>

        <toolWindow factoryClass="com.github.haoticdance.bookreaderintellijplugin.toolWindow.MyToolWindowFactory"
                    id="R3 Reader" icon="/icons/book.svg"/>
    </extensions>
</idea-plugin>
